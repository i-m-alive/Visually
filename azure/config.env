# ============================================================================
# Visually — Azure deployment configuration (NON-secret values)
# Edit these, then run ./deploy.sh from the azure/ folder.
# ACR_NAME and STORAGE_ACCT must be GLOBALLY UNIQUE — change the suffix if a
# name is already taken (deploy.sh will tell you).
# ============================================================================

# Subscription (Azure for Students). Leave blank to use your current default.
SUBSCRIPTION_ID="b902c3d7-fcea-47f2-9708-50bd7b415ed5"

# Region. This student subscription's policy only allows:
#   malaysiawest, southeastasia, eastasia, koreacentral, austriaeast
# Student subs allow only ONE Container Apps environment per SUBSCRIPTION, and
# it already exists (navispark-env, southeastasia). We reuse it, so everything
# lives in southeastasia.
LOCATION="southeastasia"

# Resource group for our resources (created if missing).
RG="visually-rg"

# Azure Container Registry — 5-50 chars, lowercase letters + numbers only, GLOBALLY UNIQUE.
ACR_NAME="visuallyacr0615"

# EXISTING Container Apps environment to deploy into (shared, 1-per-subscription
# limit) and the resource group that owns it.
ACA_ENV="navispark-env"
ACA_ENV_RG="navispark-rg"

# Prefix for all our container apps, to avoid name clashes in the shared env.
APP_PREFIX="vly-"

# Storage account for persistent volumes — 3-24 chars, lowercase+numbers, GLOBALLY UNIQUE.
STORAGE_ACCT="visuallystor0615"

# Azure Files share names (created inside the storage account).
PG_SHARE="pgdata"
UPLOADS_SHARE="uploads"

# Env-level storage registration names (namespaced inside the shared env).
PG_STORAGE_NAME="vly-pgdata"
UPLOADS_STORAGE_NAME="vly-uploads"

# Managed Postgres (Azure Database for PostgreSQL Flexible Server). Postgres
# can't run on Azure Files (SMB blocks initdb's chmod), so the platform DB is
# a managed Flexible Server. Password is in secrets.env (PG_FLEX_PASSWORD).
PG_FLEX_NAME="visually-pg-0615"
PG_FLEX_USER="visadmin"
PG_FLEX_HOST="visually-pg-0615.postgres.database.azure.com"
PG_DB_NAME="visually_platform"

# Image tag applied to every image built into ACR.
TAG="v1"

# Bedrock model IDs (must match what your AWS account has access to).
BEDROCK_SONNET_MODEL_ID="us.anthropic.claude-sonnet-4-5-20250929-v1:0"
BEDROCK_HAIKU_MODEL_ID="us.anthropic.claude-sonnet-4-5-20250929-v1:0"
BEDROCK_VISION_MODEL_ID="us.anthropic.claude-opus-4-5-20251101-v1:0"
BEDROCK_MAX_TOKENS="8192"
BEDROCK_TEMPERATURE="0.0"

# Redshift Data API: connect as svc_powerbi (has staging grants) via Secrets Manager.
REDSHIFT_DATA_API_SECRET_ARN="arn:aws:secretsmanager:us-east-1:971110686091:secret:visually/redshift/svc_powerbi-N0v4de"
