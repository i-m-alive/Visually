# ============================================================================
# Visually — SECRET deployment values.
# Copy this file to  secrets.env  and fill in real values.
#   cp secrets.env.example secrets.env
# secrets.env is git-ignored and is loaded into Azure Container Apps as
# encrypted "secrets" (not plain env vars). NEVER commit secrets.env.
# ============================================================================

# --- AWS Bedrock credentials (all LLM calls go through Bedrock) ---
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""
# Optional — only for temporary / assume-role credentials. Leave blank otherwise.
AWS_SESSION_TOKEN=""

# --- App secrets ---
# 32+ char random string.  Generate:  openssl rand -hex 32
JWT_SECRET=""
# Fernet key. Generate:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=""

# --- Postgres credentials (used inside the cluster only) ---
POSTGRES_USER="visually"
POSTGRES_PASSWORD="visually"
POSTGRES_DB="visually_platform"
