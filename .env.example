# AWS Bedrock (replaces Anthropic API key — all LLM calls go through Bedrock)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=           # optional, for temporary credentials / assume-role

# Platform DB (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://visually:visually@localhost:5432/visually_platform
DATABASE_SYNC_URL=postgresql://visually:visually@localhost:5432/visually_platform

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=change-me-in-production-use-32-char-min
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=30

# Encryption (for DB passwords stored in platform DB — generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
ENCRYPTION_KEY=

# Services (internal Docker network)
AGENT_SERVICE_URL=http://agent_service:8001
QUERY_EXECUTOR_URL=http://query_executor:8002
SCHEMA_CRAWLER_URL=http://schema_crawler:8003
RENDER_SERVICE_URL=http://render_service:3001

# File storage — MinIO for local dev, AWS S3 for production
# Local dev: keep S3_ENDPOINT_URL pointing to MinIO
# Production: set S3_ENDPOINT_URL= (empty) and set AWS S3 bucket
S3_ENDPOINT_URL=http://localhost:9000
S3_BUCKET_NAME=visually-uploads
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin

# Next.js
NEXT_PUBLIC_API_URL=http://localhost:8001
NEXT_PUBLIC_WS_URL=ws://localhost:8001
